# Backend
DATABASE_URL=file:./data/terminal-proxy.db
FRONTEND_URL=http://localhost:5173
BACKEND_PORT=3001

# Redis
REDIS_URL=redis://localhost:6379

# Terminal Agent / SignalR client
SIGNALR_HUB_URL=http://localhost:5000
SERVICE_API_KEY=your-service-api-key-here
SERVICE_ID=my-service-instance
TENANT_ID=your-workspace-id
WHITELISTED_PATHS=/home,/var/log
# Leave empty to use the platform default shell.
# On Windows the default is powershell.exe -NoLogo -NoProfile for a clean web terminal.
SHELL_OVERRIDE=
