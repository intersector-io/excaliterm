# Backend
DATABASE_URL=file:./data/terminal-proxy.db
FRONTEND_URL=http://localhost:5173
BACKEND_PORT=3001

# Shared secret used by the SignalR hub to authenticate its internal
# calls to the backend (e.g. /api/validate-key). Must be at least 32
# characters. Generate with: openssl rand -hex 32
INTERNAL_API_SECRET=replace-me-with-a-random-value-at-least-32-chars

# Set to "true" only when the backend sits behind a trusted reverse proxy
# (nginx/Traefik). When true, the rate-limiter reads the last entry of
# X-Forwarded-For as the client IP. When false (default), it uses the TCP
# socket peer address, which cannot be spoofed by clients.
TRUST_PROXY=false

# Redis
REDIS_URL=redis://localhost:6379

# Terminal Agent / SignalR client
SIGNALR_HUB_URL=http://localhost:5000
SERVICE_API_KEY=your-service-api-key-here
SERVICE_ID=my-service-instance
WORKSPACE_ID=your-workspace-id
# Comma-separated filesystem roots the agent will expose.
# Empty = no filesystem access (file browser/editor disabled).
# You can also pass --allow <path> (repeatable) or positional args on the CLI.
WHITELISTED_PATHS=/home,/var/log
# Leave empty to use the platform default shell.
# On Windows the default is powershell.exe -NoLogo -NoProfile for a clean web terminal.
SHELL_OVERRIDE=
